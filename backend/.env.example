# Database Configuration
# Option 1: Use DATABASE_URL (recommended for Render, Heroku, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/arroz_con_code

# Option 2: Use individual credentials (local development)
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=arroz_con_code

# Server
PORT=5000
NODE_ENV=development

# JWT
# Generate jwt secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# OpenAI API
OPENAI_API_KEY=sk-your_api_key_here

# Gemini API (for fact-checking)
GEMINI_API_KEY=your_gemini_api_key_here
